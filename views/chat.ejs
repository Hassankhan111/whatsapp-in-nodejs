      <%- include('partials/layout') %>
      
         <!-- Chat Section -->
            <div class="col-sm-6 col-md-6 col-lg-7 p-0 chat-section">
              <!--chat header--- call and vadeos--> 
                <div
                    class="chat-header border border-1 d-flex justify-content-between align-items-center p-3 border-bottom">
                    <div class="d-flex align-items-center">
                        <img src="https://i.pravatar.cc/50?img=1" alt="User Avatar" class="rounded-circle me-3">
                     
                        <div>
                            <h6 class="mb-0">John Doe</h6>
                            <small class="text-success">Online</small>
                        </div>
                    </div>

                    <div class="header-tool d-flex gap-3">
                        <a href="#" class="text-decoration-none">
                            📞 Call
                        </a>
                        <a href="#" class="text-decoration-none">
                            🎥 Video
                        </a>
                    </div>
                </div>
               <!-- Chat Body -->
                <div class="chat-body">

                        <!-- Received -->
                        <div class="message-row received">
                            <div class="message received">
                                Hello Hello Hello Hello Hello Hello Hello Hello👋
                            </div>
                        </div>

                        <!-- Sent -->
                        <div class="message-row sent m-3">
                            <div class="message sent">
                                Hi, how are youhhhhhhhhbbbbbbbjjjkjhgkhkjgjfjjhg
                            </div>
                        </div>

                </div>
               <!-- Chat Footer -->
                <div class="chat-footer p-3">
                    <div class="input-group">
                        <button class="btn btn-light">
                            <i class="bi bi-emoji-smile"></i>
                        </button>

                        <input type="text" class="form-control" placeholder="Type a message">

                        <button class="btn btn-light">
                            <i class="bi bi-paperclip"></i>
                        </button>

                        <button class="btn btn-success">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>