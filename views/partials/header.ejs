<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"
        integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y"
        crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="bootstrap.min.css">
    <title>header page</title>
</head>

<body>
    <div class="container-fluid vh-100">
        <div class="row vh-100">
            <!-- Sidebar Menu -->
            <div class="col-sm-3 col-md-2 col-lg-1 border border-2 sidebar-menu p-0">
                <ul class="nav flex-column h-100 sidbar-ul">
                    <li class="nav-item pt-2">
                        <a class="nav-link" href="<% '/' %>">
                            <i class="f-awesome fa-solid fa-comment"></i>
                            <span class="chat-text">Chats</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="f-awesome fa-regular fa-circle-dot"></i>
                            <span class="chat-text">Status</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="f-awesome fa-solid fa-users"></i>
                            <span class="chat-text">Community</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="f-awesome fa-solid fa-tv"></i>
                            <span class="chat-text">Channels</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="f-awesome fa-solid fa-toolbox"></i>
                            <span class="chat-text">Tools</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="f-awesome fa-solid fa-bullhorn"></i>
                            <span class="chat-text">Advertise</span>
                        </a>
                    </li>

                    <!-- Push bottom -->
                    <div class="mt-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="f-awesome fa-solid fa-photo-film"></i>
                                <span class="chat-text">Media</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="f-awesome fa-solid fa-gear"></i>
                                <span class="chat-text">Settings</span>
                            </a>
                        </li>

                        <li class="nav-item mb-3">
                            <a class="nav-link" href="#">
                                <i class="f-awesome fa-regular fa-circle-user"></i>
                                <span class="chat-text">Profile</span>
                            </a>
                        </li>
                    </div>

                </ul>
            </div>
    <!-- second header leftside bar -->
             <!-- Chat List Sidebar -->
            <div class="col-sm-3 col-md-4 col-lg-4 sidebar p-0 border border-1">

                <div class="sidebar-header d-flex justify-content-between align-items-center p-3">
                    <h4 class="m-0 fw-bold">WhatsApp</h4>

                    <div class="d-flex gap-2">

                        <a class="nav-link icon-btn" href="#">
                            <i class="bi bi-chat-left-text"></i>
                            <span class="tooltip-text">New Chat</span>
                        </a>

                        <a class="nav-link icon-btn" href="#">
                            <i class="bi bi-three-dots-vertical"></i>
                            <span class="tooltip-text">Menu</span>
                        </a>

                    </div>
                </div>
                <!-- search bar-->
                <div class="search-bar">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Search or start new chat">
                </div>
                <!-- chat status all unread favorate group-->
                <nav class="navbar group-btn m-2">
                    <ul class="navbar-nav flex-row flex-wrap gap-3">
                        <li class="nav-item"><button class="allbtn">All</button></li>
                        <li class="nav-item"><button class="unreadbtn">Unread</button></li>
                        <li class="nav-item"><button class="favoratebtn">Favorite</button></li>
                        <li class="nav-item"><button class="groupbtn">Group</button></li>
                    </ul>
                </nav>
                <!-- Chat List -->
                <div class="chat-list">
                    <!-- Chat Item1 -->
                    <table class="table table-hover">
                        <tbody>
                            <tr>
                                <th>
                                    <a href="/chat/<%= user.id %>" class="chat-link text-decoration-none text-dark">
                                        <div
                                            class="chat-item d-flex justify-content-between align-items-center p-3 border-bottom">
                                            <!-- Left Side -->
                                                
                                            <div class="d-flex align-items-center">
                                                <img src="<%= /images/user.profile_photo_url %>" class="rounded-circle me-3"
                                                    alt="user">

                                                <div>
                                                    <h6 class="mb-0"><%= user.username %></h6>
                                                    <small class="text-muted">
                                                        <i class="typing-message bi bi-pencil-fill"></i> Typing...
                                                    </small>
                                                </div>
                                            </div>

                                            <!-- Right Side -->
                                            <div class="d-flex flex-column align-items-end">

                                                <!-- Time -->
                                                <small class="text-success mb-2">7:05 AM</small>

                                                <!-- Dropdown -->
                                                <div class="dropdown">
                                                    <a href="#" class="text-dark" data-bs-toggle="dropdown">
                                                        <i class="bi bi-three-dots-vertical"></i>
                                                    </a>

                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item" href="#">
                                                                <i class="bi bi-archive me-2"></i> Archive Chat
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item" href="#">
                                                                <i class="bi bi-bell-slash me-2"></i> Mute Notifications
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item" href="#">
                                                                <i class="bi bi-pin-angle me-2"></i> Pin Chat
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item" href="#">
                                                                <i class="bi bi-tag me-2"></i> Label Chat
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item" href="#">
                                                                <i class="bi bi-envelope me-2"></i> Mark as Unread
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item" href="#">
                                                                <i class="bi bi-star me-2"></i> Add to Favorites
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item" href="#">
                                                                <i class="bi bi-trash me-2"></i> Clear Chat
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item text-danger" href="#">
                                                                <i class="bi bi-box-arrow-right me-2"></i> Exit Group
                                                            </a>
                                                        </li>
                                                    </ul>
                                                </div>

                                            </div>
                                        </div>
                                    </a>
                                </th>
                            </tr>
                            <!-- Chat Item2 -->
                            <tr>
                                <th>
                                    <a href="chat.html" class="chat-link text-decoration-none text-dark">
                                        <div
