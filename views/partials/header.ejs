                            <!-- Chat Item 3 -->
                            <tr>
                                <th>
                                    <a href="chat.html" class="chat-link text-decoration-none text-dark">
                                        <div
                                            class="chat-item d-flex justify-content-between align-items-center p-3 border-bottom">
                                            <!-- Left Side -->
                                            <div class="d-flex align-items-center">
                                                <img src="https://i.pravatar.cc/50?img=1" class="rounded-circle me-3"
